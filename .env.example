# Imago Configuration
IMAGO_HOST=0.0.0.0
IMAGO_PORT=8420

# Model settings
IMAGO_MODEL=schnell
IMAGO_STEPS=4
IMAGO_WIDTH=1024
IMAGO_HEIGHT=1024
IMAGO_QUANTIZE=8

# Output
IMAGO_OUTPUT_DIR=./output

# Prompt expansion provider: bailian | claude | qwen
IMAGO_LLM_PROVIDER=bailian

# LLM - Bailian (Alibaba Cloud DashScope, OpenAI-compatible)
IMAGO_BAILIAN_API_KEY=
IMAGO_BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
IMAGO_BAILIAN_MODEL=qwen3.5-plus

# LLM - Claude
IMAGO_ANTHROPIC_API_KEY=
IMAGO_CLAUDE_MODEL=claude-sonnet-4-20250514

# LLM - Qwen via Ollama (local)
IMAGO_OLLAMA_BASE_URL=http://localhost:11434/v1
IMAGO_QWEN_MODEL=qwen2.5:14b

# Feishu (M4)
IMAGO_FEISHU_WEBHOOK_URL=
